rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Pillar 8 default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers (Pillar 3 & 4)
    function isSignedIn() {
      return request.auth != null;
    }

    // Enforce email verification (optional but recommended where supported)
    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Bootstrapped Admin check (User email from runtime environment + verified)
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'borborschool.admin@gmail.com' && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Entity Validation Blueprints (Pillar 2 - Anti-Update-Gap)
    function isValidUser(data) {
      return data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 120 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.photoURL is string && data.photoURL.size() <= 1000 &&
             data.isAdmin is bool &&
             data.createdAt is timestamp;
    }

    function isValidTrack(data) {
      return data.id is string && data.id.size() >= 1 && data.id.size() <= 128 &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 150 &&
             data.artist is string && data.artist.size() >= 1 && data.artist.size() <= 150 &&
             data.audioUrl is string && data.audioUrl.size() >= 1 && data.audioUrl.size() <= 1200 &&
             data.coverUrl is string && data.coverUrl.size() <= 1200 &&
             data.duration is int && data.duration >= 0 &&
             data.genre is string && data.genre.size() <= 60 &&
             data.description is string && data.description.size() <= 2000 &&
             data.lyrics is string && data.lyrics.size() <= 10000 &&
             data.plays is int && data.plays >= 0 &&
             data.likesCount is int && data.likesCount >= 0 &&
             data.sharesCount is int && data.sharesCount >= 0 &&
             data.uploadedBy is string && data.uploadedBy.size() >= 1 && data.uploadedBy.size() <= 128 &&
             data.createdAt is timestamp;
    }

    function isValidLike(data) {
      return data.id is string && data.id.size() >= 1 && data.id.size() <= 256 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.trackId is string && data.trackId.size() <= 128 &&
             data.createdAt is timestamp;
    }

    function isValidComment(data) {
      return data.id is string && data.id.size() >= 1 && data.id.size() <= 128 &&
             data.trackId is string && data.trackId.size() <= 128 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userDisplayName is string && data.userDisplayName.size() <= 100 &&
             data.userPhotoURL is string && data.userPhotoURL.size() <= 1000 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 1500 &&
             data.createdAt is timestamp;
    }

    function isValidPlaylist(data) {
      return data.id is string && data.id.size() >= 1 && data.id.size() <= 128 &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 120 &&
             data.description is string && data.description.size() <= 1000 &&
             data.coverUrl is string && data.coverUrl.size() <= 1200 &&
             data.creatorId is string && data.creatorId == request.auth.uid &&
             data.creatorName is string && data.creatorName.size() <= 100 &&
             data.trackIds is list && data.trackIds.size() <= 200 &&
             data.isPublic is bool &&
             data.createdAt is timestamp;
    }

    // Rules for USERS collection
    match /users/{userId} {
      allow get: if isSignedIn();
      // PII Protection: Standard users cannot do unfiltered scans of all users. Queries must be constrained.
      allow list: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().isAdmin == false;
      
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().uid == existing().uid &&
                    // regular users cannot modify isAdmin field to self-elevate
                    incoming().isAdmin == existing().isAdmin;
                    
      allow delete: if isAdmin();
    }

    // Rules for TRACKS collection
    match /tracks/{trackId} {
      // Music stream metadata is globally discoverable by anyone
      allow read: if true;
      
      // Upload track: Admins only
      allow create: if isAdmin() && isValidTrack(incoming()) && incoming().createdAt == request.time;
      
      // Update track: 
      // Tier 1: Admin can update all fields (with validation)
      // Tier 2: Regular user can ONLY update play counts, likesCount, sharesCount counters
      allow update: if isSignedIn() && (
        (isAdmin() && isValidTrack(incoming())) ||
        (
          isValidTrack(incoming()) &&
          incoming().id == existing().id &&
          incoming().title == existing().title &&
          incoming().artist == existing().artist &&
          incoming().audioUrl == existing().audioUrl &&
          incoming().coverUrl == existing().coverUrl &&
          incoming().uploadedBy == existing().uploadedBy &&
          incoming().createdAt == existing().createdAt &&
          incoming().diff(existing()).affectedKeys().hasOnly(['plays', 'likesCount', 'sharesCount'])
        )
      );
      
      allow delete: if isAdmin();

      // Sub-collection for COMMENTS inside Tracks (Pillar 1 Master Gate pattern)
      match /comments/{commentId} {
        allow read: if true;
        
        allow create: if isSignedIn() && isValidComment(incoming()) && 
                      incoming().createdAt == request.time &&
                      isValidId(commentId) &&
                      // Enforce compound relational integrity: track must exist
                      exists(/databases/$(database)/documents/tracks/$(trackId));
                      
        allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      isValidComment(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().trackId == existing().trackId &&
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['content']);
                      
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // Rules for LIKES collection (Pillar 5 / 7 Atomicity & Guarding)
    match /likes/{likeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidLike(incoming()) && 
                    incoming().createdAt == request.time &&
                    isValidId(likeId) &&
                    // Relational integrity check
                    exists(/databases/$(database)/documents/tracks/$(incoming().trackId));
                    
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for PLAYLISTS collection
    match /playlists/{playlistId} {
      // Anyone can fetch a single playlist, but list/queries depend on privacy flag
      allow get: if resource.data.isPublic == true || (isSignedIn() && resource.data.creatorId == request.auth.uid);
      
      allow list: if resource.data.isPublic == true || (isSignedIn() && resource.data.creatorId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidPlaylist(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && resource.data.creatorId == request.auth.uid && 
                    isValidPlaylist(incoming()) &&
                    incoming().creatorId == existing().creatorId &&
                    incoming().createdAt == existing().createdAt;
                    
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }
  }
}
